# ============================================================================
# Bloom Analytics — environment variable template
# Copy to `.env` for local dev (both are git-ignored). In production, set these
# values in Vercel (frontend) and Render (backend) dashboards.
# ============================================================================

# --- Frontend (Vite) ---------------------------------------------------------
# Base URL for the Flask backend. Empty or localhost in dev; Render URL in prod.
VITE_API_URL=http://localhost:5000

# Firebase Auth (Web SDK — these are safe to expose in the client bundle, but
# still belong in env so they're swappable per environment).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Backend (Flask) — set in Render dashboard, not in the frontend .env -----
# FLASK_ENV=production
# Comma-separated list of allowed origins for CORS + Socket.IO.
# ALLOWED_ORIGINS=https://your-app.vercel.app
# Required for the AI agent feature. Leave unset to disable the feature.
# OPENAI_API_KEY=
# Optional news provider (currently not required).
# NEWS_API_KEY=
